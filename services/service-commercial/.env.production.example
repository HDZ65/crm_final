# Production environment template - copy to .env.production and fill in real values
# service-commercial - production Configuration
NODE_ENV=production

# Database (Production PostgreSQL instance)
DB_HOST=prod-crm-postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_DATABASE=prod_commercial
DB_SYNCHRONIZE=false

# gRPC / HTTP
GRPC_PORT=50053
HTTP_PORT=3053

# NATS (Production NATS instance)
NATS_URL=nats://prod-crm-nats:4222

# JWT (Replace with real production secret)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
