# Staging environment template - copy to .env.staging and fill in real values
NODE_ENV=staging

# Database
DB_HOST=staging-crm-postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_IN_STAGING
DB_DATABASE=commercial_db
DB_SYNCHRONIZE=false

# gRPC (multi-port consolidated service)
COMMERCIAUX_GRPC_PORT=50053
COMMISSION_GRPC_PORT=50054
CONTRATS_GRPC_PORT=50055
PRODUCTS_GRPC_PORT=50064
HTTP_PORT=3053

# NATS
NATS_URL=nats://staging-crm-nats:4222

# JWT
JWT_SECRET=CHANGE_ME_IN_STAGING
