# Production environment template - copy to .env.production and fill in real values
# service-engagement - production Configuration
NODE_ENV=production

# Database (Production PostgreSQL instance)
DB_HOST=prod-crm-postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_DATABASE=prod_engagement
DB_SYNCHRONIZE=false

# gRPC / HTTP
GRPC_PORT=50051
HTTP_PORT=3061

# NATS (Production NATS instance)
NATS_URL=nats://prod-crm-nats:4222

# Redis (Production Redis instance)
REDIS_HOST=prod-crm-redis
REDIS_PORT=6379

# Encryption & OAuth (Replace with real production values)
ENCRYPTION_KEY=CHANGE_ME_IN_PRODUCTION
ZOOM_CLIENT_ID=CHANGE_ME_IN_PRODUCTION
ZOOM_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION
GOOGLE_CLIENT_ID=CHANGE_ME_IN_PRODUCTION
GOOGLE_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION
MICROSOFT_CLIENT_ID=CHANGE_ME_IN_PRODUCTION
MICROSOFT_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION
