# Staging environment template - copy to .env.staging and fill in real values
NODE_ENV=staging

# Database
DB_HOST=staging-crm-postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_IN_STAGING
DB_DATABASE=engagement_db
DB_SYNCHRONIZE=false

# gRPC / HTTP
GRPC_PORT=50051
HTTP_PORT=3061

# NATS
NATS_URL=nats://staging-crm-nats:4222

# Redis
REDIS_HOST=staging-crm-redis
REDIS_PORT=6379

# Encryption & OAuth
ENCRYPTION_KEY=CHANGE_ME_IN_STAGING
ZOOM_CLIENT_ID=CHANGE_ME_IN_STAGING
ZOOM_CLIENT_SECRET=CHANGE_ME_IN_STAGING
GOOGLE_CLIENT_ID=CHANGE_ME_IN_STAGING
GOOGLE_CLIENT_SECRET=CHANGE_ME_IN_STAGING
MICROSOFT_CLIENT_ID=CHANGE_ME_IN_STAGING
MICROSOFT_CLIENT_SECRET=CHANGE_ME_IN_STAGING
