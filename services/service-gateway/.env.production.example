# Production environment template - copy to .env.production and fill in real values
# service-gateway - production Configuration
NODE_ENV=production

# HTTP
HTTP_PORT=3405

# NATS (Production NATS instance)
NATS_URL=nats://prod-crm-nats:4222

# gRPC (Production service-commercial address)
GRPC_CONTRAT_URL=prod-crm-service-commercial:50053

# Keycloak (Replace with real production values)
KEYCLOAK_ISSUER_URL=CHANGE_ME_IN_PRODUCTION
KEYCLOAK_GATEWAY_CLIENT_ID=CHANGE_ME_IN_PRODUCTION
