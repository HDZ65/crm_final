# service-integrations - staging Configuration
NODE_ENV=staging

# Database
DB_HOST=staging-crm-postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=staging_integrations
DB_SYNCHRONIZE=false

# gRPC / HTTP
GRPC_PORT=50059
HTTP_PORT=3409

# NATS
NATS_URL=nats://staging-crm-nats:4222

# JWT
JWT_SECRET=your-staging-secret-key-here
MIGRATIONS_RUN=false

# External integrations
WINLEADPLUS_API_URL=https://winleadplus.com/api/prospects
WOOCOMMERCE_API_URL=
