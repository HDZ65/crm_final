# Production environment template - copy to .env.production and fill in real values
# service-logistics - production Configuration
NODE_ENV=production

# Database (Production PostgreSQL instance)
DB_HOST=prod-crm-postgres
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=CHANGE_ME_IN_PRODUCTION
DB_DATABASE=prod_logistics
DB_SYNCHRONIZE=false

# gRPC
GRPC_HOST=0.0.0.0
GRPC_PORT=50060

# HTTP (Port of the API / Healthcheck)
HTTP_PORT=3060

# NATS (Production NATS instance)
NATS_URL=nats://prod-crm-nats:4222

# JWT (Replace with real production secret)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION
